# ─── ASHOID — Variables d'environnement ───────────────────────────
# Copiez ce fichier en .env et remplissez les valeurs

# Port du serveur (Render/Railway l'injecte automatiquement)
PORT=3000

# Répertoire de stockage des données (chemin absolu ou relatif)
DATA_DIR=./data

# Secret de session (changez en production !)
SESSION_SECRET=ashoid_secret_change_moi_en_prod_2025

# Environnement
NODE_ENV=production

# CORS — domaine autorisé (* = tous, ou votre domaine)
CORS_ORIGIN=*
